{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All The Context Human-Readable Update Channel Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "channel", "version", "source_commit",
    "candidate_sha256", "manifests"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "channel": {"const": "beta"},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-beta\\.[1-9][0-9]*$"
    },
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "candidate_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "manifests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "architecture", "path", "sha256"],
        "properties": {
          "platform": {"enum": ["windows", "macos", "linux"]},
          "architecture": {"enum": ["x86_64", "arm64"]},
          "path": {"type": "string", "pattern": "^beta/"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
