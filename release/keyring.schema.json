{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All The Context OTA Public-Key Trust Store",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "keys"],
  "properties": {
    "schema_version": {"const": 1},
    "keys": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key_id", "algorithm", "public_key", "public_key_sha256", "channels", "status"
        ],
        "properties": {
          "key_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
          },
          "algorithm": {"const": "Ed25519"},
          "public_key": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{43}$"
          },
          "public_key_sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "channels": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["stable", "beta"]}
          },
          "status": {"enum": ["active", "revoked"]}
        }
      }
    }
  }
}
